{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": [
    "ai-setup-AGENTS.md"
  ],
  "agent": {
    "plan": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "permission": {
        "task": "deny"
      }
    },
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "permission": {
        "task": "deny"
      }
    },
    "plan-lite": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max",
      "permission": {
        "task": "deny",
        "edit": "ask",
        "bash": "ask"
      },
      "description": "Lightweight plan agent using Flash Free with Think Max reasoning"
    },
    "build-lite": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "permission": {
        "task": "deny"
      },
      "description": "Lightweight build agent using Flash Free with Think High reasoning"
    }
  }
}